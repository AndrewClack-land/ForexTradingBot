# Telegram
TELEGRAM_TOKEN=CHANGE_ME
TELEGRAM_CHANNEL_ID=CHANGE_ME
# Comma-separated user/chat ids allowed to run /status /open /report /universe
TELEGRAM_ADMIN_IDS=

# MT5
MT5_LOGIN=CHANGE_ME
MT5_PASSWORD=CHANGE_ME
MT5_SERVER=FxPro-MT5 Demo

# tvDatafeed
TV_LOGIN_MODE=nologin
TV_USERNAME=
TV_PASSWORD=

# flags
POST_STARTUP_REPORT=0
REPORT_DEFAULT_LIMIT=15
LOG_TICK=0
# Broker split-leg lifecycle / break-even polling (clamped to 1..5 seconds)
MANAGEMENT_POLL_SEC=3

# Immutable setup-level telemetry tags (set a new deployment id for every VPS release)
STRATEGY_VERSION=narrative-1r2r3r-rbq-v2
STRATEGY_EXPERIMENT_ID=wr-improvement-20260716
STRATEGY_EXPERIMENT_VARIANT=rb-off
DEPLOYMENT_ID=CHANGE_ME

# Live quarantine: historical VPS journal had 0 wins / 18 closed RB setups.
# Re-enable only after walk-forward evidence on a sufficiently long snapshot.
REJECTION_BLOCK_ENTRY_ENABLED=0

# Optional demo experiments (off unless explicitly enabled)
DAILY_FLAT_ENABLED=0
DAILY_CLOSE_HOUR=21
# Stop accepting entries this many minutes before the daily close
DAILY_CLOSE_BUFFER_MIN=30
# Same-direction positive-correlation groups, e.g. EURUSD+GBPUSD
CORRELATED_GROUPS=

# Entry frequency / risk brakes
# Cooldown (minutes) per symbol after a stop-loss close
POST_SL_COOLDOWN_MIN=60
# Max executed setups per symbol per day (UTC)
MAX_SETUPS_PER_SYMBOL_PER_DAY=3
# Bot-wide daily loss limit (fraction of day-start balance)
DAILY_MAX_LOSS_PCT=0.03

# Sizing guards
# Maximum nominal Stop Loss risk per complete setup. Values above 1% are
# hard-clamped to 1%; split TP legs share this one aggregate budget.
MT5_RISK_PCT=0.01
# Fixed starting-capital risk base. Leave 0 to capture the account balance once
# into ai_data/risk_capital.json; set an explicit amount to override that file.
MT5_INITIAL_CAPITAL=0
# Cap on total lots per setup
MT5_MAX_VOLUME=10.0
# Round-turn commission per 1.0 lot in the account currency, included in sizing
MT5_COMMISSION_PER_LOT=7.0

# Vol-regime filter (IV Surface 7-signal score, computed from daily candles)
VOL_REGIME_FILTER=1
VOL_REGIME_SYMBOLS=GOLD,EURUSD,GBPUSD,USDCAD
# Block entries while R(t) >= this score (PANIC); 0 disables the score gate
VOL_REGIME_MAX_R=60
# Block setups whose TP1 is further than N x the 1-day expected move; 0 disables
EM_TP_MAX_RATIO=1.0
# Recompute the vol context at most every N minutes per symbol
VOL_REGIME_REFRESH_MIN=15
